{
  "name": "ar-viewer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "web",
    "mobile"
  ],
  "scripts": {
    "web": "npm run dev --workspace=web",
    "mobile": "npm run start --workspace=mobile",
    "dev": "concurrently \"npm run web\"",
    "install:all": "npm install"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^11.0.0",
    "metro": "0.83.5",
    "metro-config": "0.83.5",
    "metro-transform-worker": "0.83.5",
    "metro-resolver": "0.83.5",
    "metro-runtime": "0.83.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}