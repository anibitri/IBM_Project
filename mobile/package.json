{
  "name": "@ar-viewer/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios"
  },
  "dependencies": {
    "@ar-viewer/shared": "*",
    "@babel/runtime": "^7.29.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/cli-platform-ios": "^20.1.2",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.19",
    "@react-navigation/native-stack": "^7.3.0",
    "@reactvision/react-viro": "2.43.0",
    "axios": "^1.13.1",
    "react": "18.3.0",
    "react-native": "0.76.9",
    "react-native-blob-util": "^0.15.0",
    "react-native-document-picker": "^9.3.1",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-pdf": "^7.0.3",
    "react-native-permissions": "^5.5.1",
    "react-native-reanimated": "3.16.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "4.13.0",
    "react-native-sensors": "^7.3.6",
    "react-native-svg": "15.12.1",
    "react-native-tts": "^4.1.1",
    "react-native-vector-icons": "^10.3.0",
    "react-native-vision-camera": "3.9.0",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@react-native-community/cli": "^20.1.2",
    "@react-native/babel-preset": "^0.76.9",
    "@react-native/metro-config": "^0.76.9",
    "@testing-library/react-native": "^12.9.0",
    "@testing-library/jest-native": "^5.4.3",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react-test-renderer": "18.3.0",
    "fast-xml-parser": ">=5.5.7"
  },
  "jest": {
    "preset": "react-native",
    "setupFiles": [
      "<rootDir>/__mocks__/setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-vector-icons|react-native-document-picker|react-native-image-picker|react-native-vision-camera|react-native-safe-area-context|react-native-screens|react-native-gesture-handler|react-native-reanimated|react-native-svg|@reactvision)/)"
    ],
    "moduleNameMapper": {
      "\\.(png|jpg|jpeg|gif|webp)$": "<rootDir>/__mocks__/fileMock.js",
      "@ar-viewer/shared": "<rootDir>/../shared/index.js",
      "@react-native-async-storage/async-storage": "<rootDir>/__mocks__/asyncStorageMock.js",
      "^react$": "<rootDir>/node_modules/react",
      "^react/(.*)$": "<rootDir>/node_modules/react/$1",
      "^react-test-renderer$": "<rootDir>/../node_modules/react-test-renderer",
      "^react-test-renderer/(.*)$": "<rootDir>/../node_modules/react-test-renderer/$1"
    },
    "testMatch": ["**/__tests__/**/*.test.{js,jsx,ts,tsx}"]
  },
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "test": "jest",
    "test:watch": "jest --watch"
  }
}
